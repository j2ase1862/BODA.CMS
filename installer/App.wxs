<?xml version="1.0" encoding="utf-8"?>
<!-- BODA.CMS 모니터 앱 MSI — tools\package.ps1 이 빌드한다.
     시작 메뉴·바탕화면 바로가기 포함. 전처리 변수(-d): Version, PayloadDir -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="BODA.CMS 모니터"
           Manufacturer="BODA"
           Version="$(var.Version)"
           UpgradeCode="0D982AEA-2F3B-49B4-B2ED-756692A974D2"
           Language="1042" Codepage="949"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="더 높은 버전이 이미 설치되어 있습니다. 먼저 제거한 뒤 설치하세요." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="BODA.CMS" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="Payload" Directory="INSTALLFOLDER">
      <Files Include="$(var.PayloadDir)\**" />
    </ComponentGroup>

    <!-- 바로가기: exe 는 Payload 하베스팅에 포함되므로 레지스트리 KeyPath 방식의 별도 컴포넌트로 만든다 -->
    <Component Id="Shortcuts" Directory="INSTALLFOLDER" Bitness="always64">
      <RegistryValue Root="HKLM" Key="Software\BODA\BODA.CMS" Name="Installed"
                     Type="integer" Value="1" KeyPath="yes" />
      <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder" Name="BODA.CMS 모니터"
                Target="[INSTALLFOLDER]BODA.CMS.exe" WorkingDirectory="INSTALLFOLDER" />
      <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="BODA.CMS 모니터"
                Target="[INSTALLFOLDER]BODA.CMS.exe" WorkingDirectory="INSTALLFOLDER" />
    </Component>

    <Feature Id="Main" Level="1">
      <ComponentGroupRef Id="Payload" />
      <ComponentRef Id="Shortcuts" />
    </Feature>

  </Package>
</Wix>
