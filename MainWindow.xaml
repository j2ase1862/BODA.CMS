<Window x:Class="BODA.CMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BODA.CMS.Views"
        Title="BODA.CMS — 협동로봇 상태 모니터"
        Height="920" Width="1000"
        MinHeight="700" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13" Background="#FFF5F6F8">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 연결 설정 카드 (제조사 선택 + 링크 프로브) -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="16"
                BorderBrush="#FFE2E5EA" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="1" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="제조사"
                           VerticalAlignment="Center" Margin="0,0,12,8" Foreground="#FF333A45" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Padding="6,4"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding Vendors}"
                          SelectedItem="{Binding SelectedVendor}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="IP 주소"
                           VerticalAlignment="Center" Margin="0,0,12,8" Foreground="#FF333A45" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Padding="6,4"
                         VerticalContentAlignment="Center"
                         Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="포트"
                           VerticalAlignment="Center" Margin="0,0,12,8" Foreground="#FF333A45" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Padding="6,4"
                         VerticalContentAlignment="Center"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                        Content="{Binding ConnectButtonText}"
                        Command="{Binding ConnectCommand}"
                        Width="110" Margin="12,0,0,8" Padding="0,6"
                        VerticalAlignment="Stretch"
                        Background="#FF2D6CDF" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontWeight="SemiBold" />

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" Margin="0,4,0,0">
                    <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 텔레메트리 소스 카드 목록 — 선택된 제조사의 채널만큼 카드가 렌더된다(XAML 수정 불필요) -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Sources}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="16"
                            BorderBrush="#FFE2E5EA" BorderThickness="1" Margin="0,14,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="1" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SubLabel}" Foreground="#FF8A93A0"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CbmText}" Foreground="{Binding CbmBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding MlText}" Foreground="{Binding MlBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>

                            <ToggleButton Grid.Row="0" Grid.Column="1"
                                          IsChecked="{Binding IsChartMode}"
                                          Content="차트" Width="56" Padding="0,5" Margin="8,0,0,0"
                                          Cursor="Hand" FontWeight="SemiBold" />

                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0">
                                <TextBlock Text="포트" Foreground="#FF8A93A0" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="56" Padding="4,3" VerticalContentAlignment="Center"
                                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Button Grid.Row="0" Grid.Column="3"
                                    Content="{Binding ButtonText}"
                                    Command="{Binding ToggleCommand}"
                                    Width="140" Padding="0,6"
                                    Background="#FF2D6CDF" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" FontWeight="SemiBold" />

                            <!-- 표 모드: 표시 신호 선택(체크박스) — 첫 프레임 수신 시 존재하는 신호로 자동 구성 -->
                            <ItemsControl Grid.Row="1" Grid.ColumnSpan="4" Margin="0,10,0,0"
                                          ItemsSource="{Binding Signals}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChartMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,14,4" Foreground="#FF333A45" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 차트 모드: 그릴 신호 선택(1신호 = 축별 라인) -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,10,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChartMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="차트 신호" Foreground="#FF8A93A0" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox Width="140" Padding="4,3"
                                          ItemsSource="{Binding Signals}"
                                          SelectedItem="{Binding SelectedChartSignal}"
                                          DisplayMemberPath="Label" />
                            </StackPanel>

                            <!-- 표 모드: 판독 표 -->
                            <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,10,0,0"
                                    Background="#FF1B1F24" CornerRadius="6" Padding="10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChartMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Readout}" FontFamily="Consolas" FontSize="12"
                                           Foreground="#FFD6E1EC" />
                            </Border>

                            <!-- 차트 모드: 라이브 스트립 차트 -->
                            <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,10,0,0"
                                    Background="#FF1B1F24" CornerRadius="6" Padding="4" Height="240">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChartMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <views:SignalChartView />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- CBM 알림 리스트 (최신이 위) -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12"
                BorderBrush="#FFE2E5EA" BorderThickness="1" Margin="0,14,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="CBM 알림" FontWeight="SemiBold" Foreground="#FF333A45" />
                <ScrollViewer Grid.Row="1" MaxHeight="96" Margin="0,6,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 로그 -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="2"
                BorderBrush="#FFE2E5EA" BorderThickness="1" Margin="0,14,0,0">
            <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="12" Foreground="#FF2B3138"
                     Background="Transparent" BorderThickness="0" Padding="10"
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
