<Window x:Class="BODA.CMS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BODA.CMS.Views"
        Title="BODA.CMS — 협동로봇 상태 모니터"
        Height="1020" Width="1220"
        MinHeight="720" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI, Malgun Gothic" FontSize="13"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">

    <Grid Margin="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 헤더: 브랜드 워드마크 + 라이브 요약 + 도구 버튼 -->
        <Grid Grid.Row="0" Margin="2,0,2,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="10" Height="22" CornerRadius="3"
                        Background="{StaticResource AccentBrush}" Margin="0,0,10,0" />
                <TextBlock VerticalAlignment="Center" FontSize="19" FontWeight="SemiBold">
                    <Run Text="BODA" Foreground="{StaticResource TextBrush}" /><Run Text=".CMS" Foreground="{StaticResource AccentBrush}" />
                </TextBlock>
                <TextBlock Text="협동로봇 상태 모니터" Foreground="{StaticResource MutedBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="12,3,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="웹 대시보드" Padding="14,6" Margin="0,0,8,0" Click="OnDashboardClick"
                        ToolTip="감시 서버 웹 대시보드를 기본 브라우저로 엽니다 (기본 http://localhost:5100 — 다른 PC면 환경 변수 BODA_COLLECTOR_URL)" />
                <Button Content="AI 재학습" Padding="14,6" Click="OnRetrainClick"
                        ToolTip="수집 DB의 정상 운전 데이터로 이상탐지 모델을 다시 학습하고 교체합니다" />
            </StackPanel>
        </Grid>

        <!-- 본문(연결 설정·채널 카드·알림)은 스크롤 가능 — 작은 화면에서도 카드가 잘리지 않게 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0,0,2,0">
        <StackPanel>

        <!-- 연결 설정 카드 (제조사 선택 + 링크 프로브) -->
        <Border Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,14,8" MinWidth="64">
                    <TextBlock Text="제조사" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <views:HelpIcon Margin="6,0,0,0" HelpTitle="제조사 선택"
                                    HelpText="모니터링할 로봇 제조사를 선택합니다. 전환하면 실행 중인 채널이 안전하게 정지되고 해당 벤더의 채널 카드로 교체됩니다. '시뮬레이터'는 로봇 없이 가상 데이터로 전체 기능(차트·CBM·ML)을 체험할 수 있습니다. 새 제조사는 드라이버 모듈 추가만으로 이 목록에 나타납니다." />
                </StackPanel>
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding Vendors}"
                          SelectedItem="{Binding SelectedVendor}"
                          DisplayMemberPath="DisplayName" />

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,14,8" MinWidth="64">
                    <TextBlock Text="IP 주소" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <views:HelpIcon Margin="6,0,0,0" HelpTitle="컨트롤러 IP 주소"
                                    HelpText="로봇 컨트롤러의 IP 주소입니다. 모든 채널 카드가 이 주소로 접속합니다. 두산 기본값은 192.168.137.100이며 현장 설정에 따라 다를 수 있습니다(예: 192.168.1.100). 시뮬레이터 채널은 이 값을 무시합니다." />
                </StackPanel>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                         VerticalContentAlignment="Center"
                         Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,14,8" MinWidth="64">
                    <TextBlock Text="포트" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <views:HelpIcon Margin="6,0,0,0" HelpTitle="연결 테스트 포트"
                                    HelpText="아래 '연결' 버튼이 사용하는 링크 프로브 포트입니다(기본 502 = Modbus TCP). 연결 버튼은 네트워크 배선·컨트롤러 응답을 빠르게 점검하는 용도로, 홀딩 레지스터 시험 읽기까지 수행합니다. 각 채널 카드는 카드 안의 개별 포트를 사용하므로 이 값과 무관하게 동작합니다." />
                </StackPanel>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                         VerticalContentAlignment="Center"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
                        Content="{Binding ConnectButtonText}"
                        Command="{Binding ConnectCommand}"
                        Width="110" Margin="12,0,0,8"
                        VerticalAlignment="Stretch" />

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal" Margin="0,4,0,0">
                    <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                    <views:HelpIcon Margin="8,0,0,0" HelpTitle="연결 상태"
                                    HelpText="링크 프로브의 상태입니다. 회색=대기, 주황=연결 중, 초록=연결 성공, 빨강=실패. 연결을 해제하면 실행 중인 채널 카드도 함께 정리됩니다. 시험 읽기가 실패해도 TCP 연결 자체는 정상일 수 있습니다(UnitId·주소 범위 확인)." />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 텔레메트리 소스 카드 목록 — 선택된 제조사의 채널만큼 카드가 렌더된다(XAML 수정 불필요) -->
        <ItemsControl ItemsSource="{Binding Sources}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SubLabel}" Foreground="{StaticResource MutedBrush}"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CbmText}" Foreground="{Binding CbmBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding MlText}" Foreground="{Binding MlBrush}"
                                           FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" />
                                <views:HelpIcon Margin="8,0,0,0" HelpTitle="채널 카드"
                                                HelpText="로봇의 데이터 채널 하나입니다. 괄호는 (제품 등급 · 샘플링 주기 · 패시브 여부) — 등급은 채널이 주는 신호로 자동 판정되고 오른쪽 '등급' 콤보로 하향 운용할 수 있으며, '패시브'는 로봇 작업을 방해하지 않는 읽기 전용 채널이라는 뜻입니다. 표 아래 체크박스로 표시할 신호를 고를 수 있습니다.&#x0a;&#x0a;· CBM 칩: 기준선 학습(약 1분) 후 건강도 0~100 표시 — 초록≥80, 주황≥50, 빨강은 그 미만.&#x0a;· ML 칩: ONNX 이상탐지 모델의 판정 — 이상 감지 시 축·신호를 표시합니다." />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <views:HealthGauge Score="{Binding HealthScore}" Accent="{Binding CbmBrush}"
                                                   Margin="4,0,8,0"
                                                   ToolTip="CBM 건강도 (0~100) — 기준선 이탈이 클수록 낮아집니다" />
                                <RadioButton Content="표"
                                             IsChecked="{Binding View, Converter={StaticResource EnumToBool}, ConverterParameter=Table}" />
                                <RadioButton Content="차트" Margin="4,0,0,0"
                                             IsChecked="{Binding View, Converter={StaticResource EnumToBool}, ConverterParameter=Chart}" />
                                <RadioButton Content="로봇" Margin="4,0,0,0"
                                             IsChecked="{Binding View, Converter={StaticResource EnumToBool}, ConverterParameter=Robot}" />
                                <views:HelpIcon Margin="6,0,0,0" HelpTitle="표시 모드 전환"
                                                HelpText="표: 숫자 판독 표.&#x0a;차트: 라이브 스트립 차트(최근 30초, 축별 J1~J6 라인) — '차트 신호'에서 그릴 신호를 선택합니다.&#x0a;로봇: 로봇 그림 위에 관절별 상태를 표시합니다 — 관절 색이 기준선 이탈 정도(초록→주황→빨강)이고, 옆의 히트맵·추세선으로 어느 축·신호가 문제인지 한눈에 볼 수 있습니다." />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="등급" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox Width="76" VerticalContentAlignment="Center"
                                          ItemsSource="{Binding TierOptions}"
                                          SelectedItem="{Binding SelectedTier}">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                </ComboBox>
                                <views:HelpIcon Margin="6,0,12,0" HelpTitle="제품 등급 선택"
                                                HelpText="이 채널을 운용할 제품 등급입니다.&#x0a;&#x0a;· 자동(기본): 채널이 주는 신호로 등급을 자동 판정합니다 — 전류나 실측 토크가 있고 10Hz 이상이면 Pro, 아니면 Basic.&#x0a;· Basic: 등급을 강제로 내려 위치·속도만 수집합니다(전류·토크·온도 제외). Basic 라이선스 현장에서 Pro급 로봇을 운용할 때 사용합니다.&#x0a;· Pro: 자동 판정이 Pro인 채널에서만 의미가 있습니다 — 채널 능력을 넘는 상향은 되지 않습니다.&#x0a;&#x0a;모니터링 중에는 변경할 수 없습니다. 하향 운용 시 CBM·ML·차트도 걸러진 신호만 봅니다." />
                                <TextBlock Text="포트" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Width="60" VerticalContentAlignment="Center"
                                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                <views:HelpIcon Margin="6,0,0,0" HelpTitle="채널 포트"
                                                HelpText="이 채널이 접속하는 포트입니다. 채널마다 기본값이 다릅니다 — 두산 Modbus 502, 두산 DRFL 12345, JAKA 모니터 10000. 보통 바꿀 필요가 없고, 방화벽/포트포워딩 환경에서만 조정합니다." />
                            </StackPanel>

                            <Button Grid.Row="0" Grid.Column="3"
                                    Content="{Binding ButtonText}"
                                    Command="{Binding ToggleCommand}"
                                    Width="140" />

                            <!-- 표 모드: 표시 신호 선택(필 칩) — 첫 프레임 수신 시 존재하는 신호로 자동 구성 -->
                            <ItemsControl Grid.Row="1" Grid.ColumnSpan="4" Margin="0,12,0,0"
                                          ItemsSource="{Binding Signals}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding View}" Value="Table">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,8,6" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 차트 모드: 그릴 신호 선택(1신호 = 축별 라인) -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,12,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding View}" Value="Chart">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="차트 신호" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox Width="150"
                                          ItemsSource="{Binding Signals}"
                                          SelectedItem="{Binding SelectedChartSignal}"
                                          DisplayMemberPath="Label" />
                                <views:HelpIcon Margin="6,0,0,0" HelpTitle="차트 신호 선택"
                                                HelpText="차트에 그릴 신호 하나를 고릅니다(축별 J1~J6 라인 6개). 목록은 이 채널이 실제로 보내는 신호로 자동 구성됩니다. '_raw'로 끝나는 항목은 스케일 미확정 원시값 — 절대값보다 추세 관찰용입니다." />
                            </StackPanel>

                            <!-- 표 모드: 판독 표 -->
                            <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,12,0,0" Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsetPanel}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding View}" Value="Table">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Readout}" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextBrush}" />
                            </Border>

                            <!-- 차트 모드: 라이브 스트립 차트 -->
                            <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,12,0,0"
                                    Padding="4" Height="240">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsetPanel}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding View}" Value="Chart">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <views:SignalChartView />
                            </Border>

                            <!-- 로봇 모드: 3D 로봇 + 축×신호 히트맵 + 축별 추세 —
                                 신호 수(히트맵 행) + 축 수(추세선)에 따라 내용이 커지므로 높이는 자동 -->
                            <Border Grid.Row="2" Grid.ColumnSpan="4" Margin="0,12,0,0" MinHeight="240">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource InsetPanel}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding View}" Value="Robot">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <views:RobotStatusView />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- CBM 알림 리스트 (최신이 위) -->
        <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="CBM 알림" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" />
                    <views:HelpIcon Margin="6,0,0,0" HelpTitle="CBM 알림 리스트"
                                    HelpText="전 채널의 진단 알림이 최신순으로 쌓입니다(최대 100건).&#x0a;&#x0a;· 급변(빨강, Alarm): 기준선 대비 즉시값이 크게 이탈 — 충돌·급격한 부하 변화 의심.&#x0a;· 드리프트(주황, Warning): 완만한 추세 이탈 — 마모·발열 등 점진 열화 의심.&#x0a;· ML 이상(주황): 이상탐지 모델이 신호 파형의 형태 이상을 감지.&#x0a;· 복귀(초록, Info): 해당 신호가 정상 범위로 돌아옴.&#x0a;&#x0a;z는 기준선 표준편차 대비 이탈 배수입니다." />
                </StackPanel>
                <ScrollViewer Grid.Row="1" MaxHeight="96" Margin="0,8,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}"
                                           FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        </StackPanel>
        </ScrollViewer>

        <!-- 로그 — 항상 하단 고정 -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="4" Margin="0,12,0,0" Height="150">
            <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="12" Foreground="{StaticResource MutedBrush}"
                     Background="Transparent" BorderThickness="0" Padding="10"
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
